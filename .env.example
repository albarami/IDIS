# IDIS Environment Configuration Example
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL (primary store - required for production)
DATABASE_URL=postgresql://user:password@localhost:5432/idis
IDIS_DATABASE_URL=postgresql+asyncpg://idis:localdev@localhost:5432/idis
IDIS_DATABASE_ADMIN_URL=postgresql://postgres:localdev@localhost:5432/idis

# Strict runtime profile
IDIS_REQUIRE_FULL_LIVE=false
# Optional explicit strict dotenv file for local strict readiness/profile commands.
# IDIS_STRICT_DOTENV_PATH=.env

# Object storage for durable package artifacts
IDIS_OBJECT_STORE_BACKEND=filesystem
IDIS_OBJECT_STORE_BASE_DIR=var/objects

# =============================================================================
# Neo4j Aura Configuration (Graph Database for Sanad chains)
# =============================================================================
# Neo4j Aura uses encrypted connection URIs (neo4j+s:// scheme)
# Official driver documentation: https://neo4j.com/docs/python-manual/current/

# Connection URI - use neo4j+s:// for Aura (encrypted), bolt:// for local dev
# Format: neo4j+s://<instance-id>.databases.neo4j.io (Aura)
# Format: bolt://localhost:7687 (local Docker)
NEO4J_URI=bolt://localhost:7687

# Authentication credentials (from Aura console)
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=localdev123

# =============================================================================
# API Authentication
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-placeholder-not-real
OPENAI_API_KEY=sk-placeholder-not-real
# JSON map of API keys to tenant configurations
# Format: {"api-key": {"tenant_id": "uuid", "actor_id": "uuid", "name": "...", ...}}
IDIS_API_KEYS_JSON={"test-key-not-real":{"tenant_id":"00000000-0000-0000-0000-000000000001","actor_id":"local-dev-service","actor_type":"SERVICE","name":"Local Dev Service","timezone":"UTC","data_region":"us-east-1","roles":["ADMIN","AUDITOR"]}}

# Local UI development convenience only. The UI stores this in an HttpOnly cookie
# by calling /api/session/dev; the backend still validates it via IDIS_API_KEYS_JSON.
IDIS_UI_DEV_AUTH_BYPASS=true
IDIS_DEV_API_KEY=test-key-not-real

# =============================================================================
# Audit Configuration
# =============================================================================

# Path for JSONL audit log (fallback when Postgres unavailable)
IDIS_AUDIT_LOG_PATH=var/audit/audit_events.jsonl

# =============================================================================
# Rate Limiting
# =============================================================================

# Redis URL for distributed rate limiting (optional - uses in-memory if not set)
REDIS_URL=redis://localhost:6379/0
IDIS_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Observability
# =============================================================================

# OpenTelemetry exporter endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service name for tracing
OTEL_SERVICE_NAME=idis-api

# =============================================================================
# Security
# =============================================================================

# Secret key for webhook HMAC signing
# WEBHOOK_HMAC_SECRET=your-secret-key-here

# =============================================================================
# Development Settings
# =============================================================================

# Set to "development" for local dev, "production" for prod
ENVIRONMENT=development

# Enable debug mode (never in production)
DEBUG=false

# =============================================================================
# LLM Backend Selection
# =============================================================================
# Backend for claim extraction: "deterministic" (default, no network) or "anthropic"
IDIS_EXTRACT_BACKEND=deterministic
# Backend for debate roles: "deterministic" (default, no network) or "anthropic"
IDIS_DEBATE_BACKEND=deterministic

# Anthropic model overrides (only used when backend=anthropic)
IDIS_ANTHROPIC_MODEL_EXTRACT=claude-sonnet-4-20250514
IDIS_ANTHROPIC_MODEL_DEBATE_DEFAULT=claude-sonnet-4-20250514
IDIS_ANTHROPIC_MODEL_DEBATE_ARBITER=claude-opus-4-20250514

# =============================================================================
# Feature Flags
# =============================================================================
IDIS_ENABLE_VECTOR_SEARCH=false

# Vector search uses Postgres pgvector via IDIS_DATABASE_URL (may be Supabase-hosted Postgres).
# Supabase Vector SDK/API is not product-wired in Slice 62 foundation.
IDIS_EMBEDDING_BACKEND=openai
IDIS_EMBEDDING_MODEL=text-embedding-3-small
IDIS_EMBEDDING_DIMENSIONS=1536

# =============================================================================
# OCR / Media Runtime Configuration
# =============================================================================
IDIS_OCR_ENABLED=false
IDIS_OCR_ADAPTER=tesseract

# Media / Speech-to-Text (Slice 80) — OFF by default and fail-closed.
# Media is enabled only when IDIS_MEDIA_ADAPTER is set (sole supported adapter:
# "faster-whisper"). Leave it commented to keep media disabled. When enabled, strict
# readiness still requires ffmpeg + ffprobe on PATH, the faster-whisper Python package,
# and a provisioned local model (no network download unless explicitly allowed below).
# IDIS_MEDIA_ADAPTER=faster-whisper
# Local faster-whisper model directory (preferred; must contain model.bin + config.json).
# IDIS_MEDIA_STT_MODEL_PATH=models/faster-whisper
# Named faster-whisper model (used only with IDIS_MEDIA_STT_ALLOW_DOWNLOAD=true).
# IDIS_MEDIA_STT_MODEL_NAME=base
# Allow downloading a named model (default false; CI always blocks downloads).
# IDIS_MEDIA_STT_ALLOW_DOWNLOAD=false
# Per-file media transcription timeout in seconds (default 30).
# IDIS_MEDIA_TIMEOUT_SECONDS=30
# Transcription language hint (default en).
# IDIS_MEDIA_LANGUAGE=en
# faster-whisper compute type (default int8).
# IDIS_MEDIA_COMPUTE_TYPE=int8
# Maximum media duration eligible for transcription, in seconds (default 600).
# IDIS_MEDIA_MAX_DURATION_SECONDS=600

# =============================================================================
# BYOL External Enrichment Credentials
# =============================================================================
IDIS_ENRICHMENT_ENCRYPTION_KEY=dev-placeholder-not-real
COMPANIES_HOUSE_API_KEY=placeholder-not-real
GITHUB_API_TOKEN=placeholder-not-real
FRED_API_KEY=placeholder-not-real
FINNHUB_API_KEY=placeholder-not-real
FMP_API_KEY=placeholder-not-real
