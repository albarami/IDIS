{
  "annotations": {
    "list": []
  },
  "description": "Monitors API uptime, error rates, and latency SLOs per tenant.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "API availability percentage (target: 99.9%)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"2..|3..\",tenant_id=\"$tenant_id\"}[30d])) / sum(rate(http_requests_total{tenant_id=\"$tenant_id\"}[30d])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "API Availability (30d rolling)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Percentage of 5xx errors over time",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\",tenant_id=\"$tenant_id\"}[5m])) / sum(rate(http_requests_total{tenant_id=\"$tenant_id\"}[5m])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "5xx Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "95th percentile GET latency (target: <300ms)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{method=\"GET\",tenant_id=\"$tenant_id\"}[5m])) by (le))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "API Latency p95 (GET)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "95th percentile POST/PATCH latency (target: <600ms)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{method=~\"POST|PATCH\",tenant_id=\"$tenant_id\"}[5m])) by (le))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "API Latency p95 (POST/PATCH)",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "slo",
    "api",
    "availability"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0,
        "label": "Tenant Id",
        "name": "tenant_id",
        "options": [],
        "query": "",
        "refresh": 1,
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "API Availability and Latency",
  "uid": "idis-api-availability",
