  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Current audit event ingestion lag (target: <5min)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "audit_ingestion_lag_seconds{tenant_id=\"$tenant_id\"}",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Audit Event Ingestion Lag",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Audit event coverage (target: 100%)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(audit_events_emitted_total{tenant_id=\"$tenant_id\"}[1h])) / sum(rate(mutating_operations_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Audit Coverage",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Missing audit events in last 24h (target: 0)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "sum(increase(audit_events_missing_total{tenant_id=\"$tenant_id\"}[24h]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Missing Audit Events (24h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Audit events emitted by event type",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "sum by (event_type) (rate(audit_events_emitted_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Audit Events by Type",
      "type": "timeseries"
    }
  ],
