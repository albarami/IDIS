        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "sum by (formula_name) (rate(calc_success_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Calc Runs by Formula",
      "type": "timeseries"
    },
    {
