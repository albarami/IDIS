{
  "annotations": {
    "list": []
  },
  "description": "Monitors debate orchestration health and completion patterns.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Debate completion rate (target: >=98%)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(debate_completed_total{tenant_id=\"$tenant_id\"}[1h])) / sum(rate(debate_started_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Debate Completion Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Debates by stop reason (CONSENSUS, STABLE_DISSENT, MAX_ROUNDS, etc.)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "sum by (stop_reason) (rate(debate_completed_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Stop Reason Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Percentage of debates stopped due to max rounds",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(debate_completed_total{stop_reason=\"MAX_ROUNDS\",tenant_id=\"$tenant_id\"}[1h])) / sum(rate(debate_completed_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Max-Rounds Stop Percentage",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Outputs rejected by Muhasabah validator",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(muhasabah_gate_rejects_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Muhasabah Gate Rejects",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "slo",
