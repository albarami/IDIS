{
  "annotations": {
    "list": []
  },
  "description": "Monitors document ingestion pipeline health and success rates.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Ingestion success rate (target: >=99%)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(ingestion_success_total{tenant_id=\"$tenant_id\"}[1h])) / sum(rate(ingestion_attempts_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Ingestion Success Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Documents successfully ingested per second",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(ingestion_success_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Documents Ingested (Rate)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Ingestion errors broken down by type",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "sum by (error_type) (rate(ingestion_errors_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Ingestion Errors by Type",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Extraction gate pass rate (target: >=95%)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(extraction_gate_pass_total{tenant_id=\"$tenant_id\"}[1h])) / sum(rate(extraction_gate_attempts_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Extraction Gate Pass Rate",
      "type": "stat"
    }
  ],
