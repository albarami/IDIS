{
  "annotations": {
    "list": []
  },
  "description": "Monitors external integration (CRM, docs, enrichment) health.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Overall integration success rate",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(integration_success_total{tenant_id=\"$tenant_id\"}[1h])) / sum(rate(integration_attempts_total{tenant_id=\"$tenant_id\"}[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Integration Success Rate (All)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Integration errors by provider (CRM, docs, enrichment)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "sum by (provider) (rate(integration_errors_total{tenant_id=\"$tenant_id\"}[5m]))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Integration Errors by Provider",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Webhook delivery success rate - GLOBAL aggregate: these counters carry no tenant label because /metrics is an unauthenticated scrape surface",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "sum(rate(webhook_delivery_success_total[1h])) / sum(rate(webhook_delivery_attempts_total[1h])) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Webhook Delivery Success Rate (global)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "95th percentile latency by integration provider",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(integration_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Integration Latency by Provider",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 39,
  "tags": [
    "slo",
    "integrations",
    "external"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "hide": 0,
        "label": "Tenant Id",
        "name": "tenant_id",
        "options": [],
        "query": "",
        "refresh": 1,
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "Integration Health",
  "uid": "idis-integration-health",
  "version": 1
}
