{
  "annotations": {
    "list": []
  },
  "description": "Monitors Sanad grade distribution and potential drift indicators.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Current distribution of Sanad grades (A/B/C/D)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {},
      "targets": [
        {
          "expr": "sum by (grade) (sanad_grades_total{tenant_id=\"$tenant_id\"})",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Grade Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Percentage of claims with grade A",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {},
      "targets": [
        {
          "expr": "sum(sanad_grades_total{grade=\"A\",tenant_id=\"$tenant_id\"}) / sum(sanad_grades_total{tenant_id=\"$tenant_id\"}) * 100",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Grade A Percentage",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Distribution of corroboration statuses",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {},
      "targets": [
        {
          "expr": "sum by (status) (sanad_corroboration_total{tenant_id=\"$tenant_id\"})",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Corroboration Status Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "95th percentile Sanad retrieval latency (target: <1.2s)",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(sanad_retrieval_duration_seconds_bucket{tenant_id=\"$tenant_id\"}[5m])) by (le))",
          "legendFormat": "{{label_name}}",
          "refId": "A"
        }
      ],
      "title": "Sanad Retrieval Latency p95",
      "type": "timeseries"
    }
  ],
