# IDIS UI Environment Variables
# Copy this file to .env.local and fill in values

# Backend API base URL (server-only, NOT exposed to browser)
# Do NOT prefix with NEXT_PUBLIC_ - this keeps the API URL server-side only
IDIS_API_BASE_URL=http://localhost:8000

# Local development auto-login only.
# Do NOT prefix these with NEXT_PUBLIC_; the dev API key must stay server-side.
IDIS_UI_DEV_AUTH_BYPASS=true
IDIS_DEV_API_KEY=test-key-not-real

# Cookie name for API key session (optional, defaults shown)
# IDIS_SESSION_COOKIE_NAME=idis_api_key

# Session cookie max age in seconds (optional, default: 8 hours)
# IDIS_SESSION_MAX_AGE=28800
